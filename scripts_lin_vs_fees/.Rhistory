# El siguiente elemento de la lista se llama "results", y es donde se han guardado
# los outputs de los modelos. "results" es de nuevo una lista con 13 elementos.
# Cada uno de esos elementos corresponde a un training fraction distinto. Por ejemplo,
# el primer elemento corresponde a una training fraction de 0.3, el segundo corresponde
# a 0.35, etc. Si queremos, por ejemplo, examinar el output de los modelos para una
# training fraction de 0.45, debermos acceder al elemento 4 de los "results":
examine_this <- eval_data[['results']][[4]]
length(examine_this)
names(examine_this)
ts <- examine_this$stats
View(ts)
