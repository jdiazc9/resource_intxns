library(ggplot2)
library(tune)
library(scales)
################################################################################
# LIST RESULTS FILES
files <- list.files('../results/', full.names = T)
#files <- files[grepl('linmod', files)]
df <- do.call(rbind,
lapply(files,
FUN = function(file) {
load(file)
s <- eval_data$s
eval_stats <- do.call(rbind,
lapply(seq_along(s),
FUN = function(i) cbind(s = s[i],
eval_data[['results']][[i]]$stats)))
cbind(isolate = gsub('eval_linmod_', '', gsub('.RData', '', gsub('eval_data_', '', basename(file)))),
eval_stats)
}))
df <- df[, c(1, 2, 3, 5, 6, 7)]
colnames(df) <- c('isolate', 'training_fraction', 'method', 'R2', 'R2_xy', 'RMSE')
df$R2_xy[df$R2_xy < 0] <- 0
df <- df[order(df$isolate, df$training_fraction, df$method), ]
View(df)
unique(df$isolate)
write.csv(df, file = 'data_R2_andrea.csv', quote = F, col.names = T, row.names = F)
write.csv(df, file = 'data_R2_andrea.csv', quote = F, row.names = F)
which(df$R2_xy > df$R2)
unqieu)df$training_fraction
unique(df$training_fraction)
ts <- df[df$isolate == 'KT' & df$training_fraction == 0.05 & df$method == 'lin1st_lasso', ]
ts <- df[df$isolate == 'KT' & df$training_fraction == 0.35 & df$method == 'lin1st_lasso', ]
unique(df$method)
ts <- df[df$isolate == 'KT' & df$training_fraction == 0.45 & df$method == 'lin1st_lasso', ]
ts <- df[df$isolate == 'KT' & df$training_fraction == 0.7 & df$method == 'lin1st_lasso', ]
ts <- df[df$isolate == 'KT' & df$method == 'concat', ]
min)ts$training_fraction
